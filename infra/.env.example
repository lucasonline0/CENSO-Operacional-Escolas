# ─── Banco de dados ────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=censo_user
DB_PASSWORD=sua_senha_forte_aqui
DB_NAME=censo_db
# Modo SSL ao montar a DSN a partir de DB_HOST. Padrão: disable (docker local).
# Em produção sem DATABASE_URL, use require para forçar TLS.
DB_SSLMODE=disable
# Ou use a DSN completa:
# DATABASE_URL=postgres://censo_user:senha@localhost:5432/censo_db?sslmode=disable

# ─── API ───────────────────────────────────────────────────────────────────────
PORT=8000
ALLOWED_ORIGINS=https://censo.seduc.pa.gov.br

# Nº de proxies reversos confiáveis à frente da API (Railway = 1). Usado para
# resolver o IP real do cliente de forma resistente a spoofing do X-Forwarded-For.
# Use 0 apenas se a API estiver exposta diretamente, sem proxy. Padrão: 1.
TRUSTED_PROXY_COUNT=1

# Gate opcional dos endpoints públicos do formulário. Se definido, a API passa
# a exigir o header X-API-Key igual a este valor. Deixe vazio para manter os
# endpoints abertos (comportamento atual). Para ATIVAR, defina aqui e também em
# NEXT_PUBLIC_API_KEY (frontend) com o MESMO valor, e redeploy ambos.
# Obs.: por ser embutida no bundle do frontend, esta chave NÃO é um segredo
# forte — serve como kill-switch e barreira contra raspagem automatizada.
# PUBLIC_API_KEY=string_aleatoria_compartilhada_com_o_frontend

# ─── Admin Dashboard ────────────────────────────────────────────────────────────
# Usuário do painel administrativo
ADMIN_USERNAME=admin_seduc_pa

# Hash bcrypt da senha (gerado com: go run ./cmd/genpasswd <senha>)
# Exemplo de senha forte: Seduc@PA#2026!Censo
ADMIN_PASSWORD_HASH=$2a$10$SUBSTITUIR_PELO_HASH_GERADO_COM_genpasswd

# Segredo JWT — use uma string aleatória longa (min 32 chars)
# Gere com: openssl rand -hex 32
ADMIN_JWT_SECRET=SUBSTITUIR_POR_STRING_ALEATORIA_LONGA_32_CHARS_MINIMO

# Para conectar ao Railway ou outro banco em nuvem:
# Cole a variável DATABASE_URL fornecida pelo Railway.
# Quando a API encontra o DATABASE_URL, ela ignora o DB_HOST, DB_USER, etc.
DATABASE_URL="postgresql://postgres:sua_senha@host_do_railway:porta/railway"

# Segredo opcional para a rota POST /v1/admin/sync-sheets (header X-Sync-Secret).
# Se vazio, a rota fica protegida apenas pelo JWT de admin.
# SYNC_SECRET=string_aleatoria_opcional

# Ambiente da aplicação (production | development). Padrão: production.
# APP_ENV=production

# ─── Google APIs ───────────────────────────────────────────────────────────────
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
SPREADSHEET_ID=seu_spreadsheet_id_aqui
DRIVE_ROOT_FOLDER_ID=seu_folder_id_aqui
# GOOGLE_IMPERSONATE_EMAIL=usuario@workspace.com

# ─── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
# Deve ser igual a PUBLIC_API_KEY (backend) quando o gate estiver ativado.
# NEXT_PUBLIC_API_KEY=string_aleatoria_compartilhada_com_o_backend
